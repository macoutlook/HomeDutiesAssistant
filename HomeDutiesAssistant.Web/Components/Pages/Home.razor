@page "/"
@rendermode InteractiveServer
@attribute [Authorize(Policy = AuthorizationPolicies.CanRead)]
@inject RagChatService Chat
@implements IDisposable

<PageTitle>Home Duties Assistant</PageTitle>

<div class="chat">
    <h1 class="visually-hidden">Home Duties Assistant chat</h1>

    <div class="messages">
        @if (_turns.Count == 0)
        {
            <p class="hint">Ask about bills, due dates, amounts, sewer emptying, etc.</p>
        }
        @foreach (var turn in _turns)
        {
            <div class="bubble @turn.Role">
                <div class="role">@(turn.Role == "user" ? "You" : "Assistant")</div>
                @if (turn.Role == "assistant" && turn.Text.Length == 0)
                {
                    <div class="text searching">Searching your home records…</div>
                }
                else
                {
                    <div class="text">@turn.Text</div>
                }
                @if (turn.Sources is { Count: > 0 })
                {
                    <details class="sources">
                        <summary>@turn.Sources.Count source(s) used</summary>
                        <ul>
                            @foreach (var hit in turn.Sources)
                            {
                                <li>@hit.Content</li>
                            }
                        </ul>
                    </details>
                }
            </div>
        }
    </div>

    <form class="composer" @onsubmit="SendAsync">
        <input @bind="_input" @bind:event="oninput"
               placeholder="Ask a question…" autofocus
               disabled="@_busy" />
        <button type="submit" disabled="@(_busy || string.IsNullOrWhiteSpace(_input))">
            @(_busy ? "…" : "Send")
        </button>
    </form>
</div>

@code {
    // Short-term conversation memory handed to the RAG core, mirroring ConsoleChat.
    private readonly List<ChatMessage> _history = new();
    // UI-facing turns (mutable so we can append streamed tokens in place).
    private readonly List<ChatTurn> _turns = new();
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private string _input = "";
    private bool _busy;
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    private long _homeId;

    protected override async Task OnInitializedAsync()
        => _homeId = JwtTokenService.HomeId((await AuthState).User) ?? 0;

    private async Task SendAsync()
    {
        var question = _input.Trim();
        if (string.IsNullOrWhiteSpace(question) || _busy) return;

        _input = "";
        _busy = true;
        _turns.Add(new ChatTurn("user") { Text = question });
        var assistant = new ChatTurn("assistant");
        _turns.Add(assistant);

        try
        {
            // Retrieval completes when AskAsync returns; tokens stream after.
            var answer = await Chat.AskAsync(question, _history, _homeId, _cancellationTokenSource.Token);
            assistant.Sources = answer.Sources;

            await foreach (var token in answer.Tokens.WithCancellation(_cancellationTokenSource.Token))
            {
                assistant.Text += token;
                await InvokeAsync(StateHasChanged); // paint each token as it arrives
            }

            _history.Add(new ChatMessage("user", question));
            _history.Add(new ChatMessage("assistant", assistant.Text));
        }
        catch (Exception exception)
        {
            assistant.Text = $"⚠ Something went wrong: {exception.Message}";
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _cancellationTokenSource.Cancel();
        _cancellationTokenSource.Dispose();
    }

    // One rendered turn. A class (not a record) so streamed tokens mutate Text in place.
    private sealed class ChatTurn(string role)
    {
        public string Role { get; } = role;
        public string Text { get; set; } = "";
        public IReadOnlyList<SearchHit>? Sources { get; set; }
    }
}