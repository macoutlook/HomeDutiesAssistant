# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# docker-compose reads it automatically.

# PostgreSQL password — used by the db container AND the app's connection string.
# NOTE: Postgres only applies this on first initialization of the data volume.
# For an existing volume, keep the original password or recreate the volume.
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing key — at least 32 bytes (256 bits). Generate one with:
#   openssl rand -base64 48
JWT_SIGNING_KEY=change-me-generate-a-32-byte-random-key

# Hostname Caddy serves and provisions TLS for.
#   - a real domain (e.g. duties.example.com) -> automatic Let's Encrypt HTTPS
#   - "localhost" -> Caddy's internal self-signed CA (fine for LAN/testing)
SITE_ADDRESS=localhost

# Host ports for the Caddy TLS proxy. Defaults are the standard 80/443; override
# only if another proxy already uses them (then browse https://localhost:HTTPS_PORT).
HTTP_PORT=80
HTTPS_PORT=443